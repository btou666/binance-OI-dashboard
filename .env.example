# 监控币对：ALL 表示自动发现并监控 Binance USDT-M 永续全量币对
MONITOR_SYMBOLS=ALL

# 数据最大保留点位（每个 symbol）
MAX_POINTS_PER_SYMBOL=500

# 采集并发数（全量币对建议 15~30）
COLLECT_CONCURRENCY=20
# 服务器循环采集间隔（毫秒，默认 600000=10分钟）
# COLLECT_INTERVAL_MS=600000

# Binance Futures API 基址（可选，用于接入自建代理）
# BINANCE_FAPI_BASE=https://fapi.binance.com

# 手动触发采集接口的 Token（可选）
COLLECT_API_TOKEN=replace-with-a-random-string

# 飞书自定义机器人 Webhook（可选，留空则只记录不推送）
FEISHU_WEBHOOK_URL=

# Vercel KV（生产建议配置）
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 如果你用的是 Upstash Redis 集成，也可用这两个（代码已兼容）
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
